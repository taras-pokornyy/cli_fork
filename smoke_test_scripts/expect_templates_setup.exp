#!/usr/local/bin/expect -f

set timeout 60

# Use TERM=dumb to prevent terminal color probing which causes OSC sequences
set env(TERM) dumb

# Debug: Print the config path
puts "DATAROBOT_CLI_CONFIG: $env(DATAROBOT_CLI_CONFIG)"

spawn dr templates setup --config $env(DATAROBOT_CLI_CONFIG)

# Handle potential authentication prompt with longer timeout
set timeout 10
expect {
    "to connect your DataRobot credentials" {
        # Auth prompt appeared - this means token validation failed
        puts "\nERROR: Authentication required - token may be invalid or config not found"
        puts "Config path: $env(DATAROBOT_CLI_CONFIG)"
        exit 1
    }
    "more" {
        # Template list appeared - continue normally
        puts "Template list loaded successfully"
    }
    timeout {
        puts "ERROR: Timeout waiting for template list or auth prompt"
        exit 1
    }
}

set timeout 360

# Filter
send -- {/}

expect "Filter"
send -- "talk\n"

sleep 1
expect "Talk to My Docs"
send -- "\r\n"

sleep 1
expect "talk-to-my-docs-agents"
send -- "\r\n"

# Phase 0: Handle Pulumi setup if it appears before the dotenv wizard.
# The Pulumi State Backend Selection screen may appear before the wizard if the
# template includes PULUMI_CONFIG_PASSPHRASE and Pulumi is installed but not
# logged in on the runner.
set timeout 30
expect {
    "Pulumi State Backend Selection" {
        puts "Pulumi setup screen detected - selecting Login locally"

        # "Login locally" is the first option, already highlighted — press enter
        send -- "\r\n"

        # After local login, a passphrase prompt may appear
        set timeout 60
        expect {
            "PULUMI_CONFIG_PASSPHRASE" {
                puts "Passphrase prompt appeared - accepting auto-generate"
                # Press enter/y to auto-generate passphrase
                send -- "\r\n"
            }
            "Variable:" {
                # Pulumi completed without passphrase, wizard started directly
                puts "Pulumi done, wizard started"
                send -- "\r\n"
            }
            "Skipped" {
                puts "Pulumi done, prompts auto-skipped"
            }
            timeout {
                puts "ERROR: Timeout after Pulumi login"
                exit 1
            }
        }
    }
    "Variable:" {
        # No Pulumi setup needed — wizard started directly
        send -- "\r\n"
    }
    "Skipped" {
        # No Pulumi setup needed — prompts auto-skipped
    }
    timeout {
        puts "ERROR: Timeout waiting for wizard or Pulumi setup"
        exit 1
    }
}

# The dotenv model briefly flashes the "Environment Variables Menu" list screen
# while it asynchronously loads prompts. We must NOT match that transient screen,
# otherwise we'd exit before the wizard runs and the .env file is never written.
#
# Phase 1: Wait for the wizard to actually start ("Variable:" is wizard-only text)
#   or for the wizard to auto-complete all prompts ("Skipped" only appears after
#   moveToNextPrompt sets skippedPrompts > 0, never on the initial flash).
# This phase also handles the transition from Pulumi back to the wizard.
# If "enter to finish" is seen here (e.g. after Phase 0 consumed "Skipped" and
# the menu is already rendered), set a flag so Phase 2 is skipped — otherwise
# Phase 2 would block forever waiting for text that was already consumed.
set already_finished 0
set timeout 60
expect {
    "Variable:" {
        # First wizard prompt appeared — accept default
        send -- "\r\n"
    }
    "Skipped" {
        # All prompts had defaults and were auto-skipped — wizard is done
    }
    "enter to finish" {
        # Menu already shown — wizard auto-completed before Phase 1 ran
        send -- "\r\n"
        set already_finished 1
    }
    timeout {
        puts "ERROR: Timeout waiting for wizard to start"
        exit 1
    }
}

# Phase 2: Handle remaining wizard prompts, then exit the menu.
# "enter to finish" only appears on the list screen AFTER the wizard completes
# and the .env file has been saved.
# Skipped if Phase 1 already handled the final "enter to finish".
if {!$already_finished} {
    set done 0
    while {!$done} {
        expect {
            "space to toggle" {
                # Multi-select list fully rendered — press Enter to accept defaults
                send -- "\r\n"
            }
            "Variable:" {
                # Next wizard prompt — press Enter to accept default
                send -- "\r\n"
            }
            "enter to finish" {
                # Back on the menu after wizard — press Enter to finish
                send -- "\r\n"
                set done 1
            }
            timeout {
                puts "ERROR: Timeout waiting for next variable prompt or menu"
                exit 1
            }
        }
    }
}

# # Component selection screen - press space to select first component, then enter
# expect "Available Components"
# sleep 1
# send -- " "
#
# sleep 1
# send -- "\r\n"

expect eof
